# Copy this file to a private path such as .deploy/compose.env before use.
# Do not commit real deployment secrets.

COMPOSE_PROJECT_NAME=personal-erp
TZ=Asia/Seoul
IMAGE_TAG=latest
API_IMAGE_NAME=personal-erp-api
WEB_IMAGE_NAME=personal-erp-web
MIGRATE_IMAGE_NAME=personal-erp-migrate

MYSQL_ROOT_PASSWORD=replace-with-long-random-mysql-root-password
MYSQL_DATABASE=personal_erp
MYSQL_USER=erp_user
MYSQL_PASSWORD=replace-with-long-random-mysql-app-password

# Use the same MySQL user/password/database above.
# URL-encode special characters in the password if needed.
DATABASE_URL=mysql://erp_user:replace-with-long-random-mysql-app-password@mysql:3306/personal_erp

# Use HTTPS origins in real deployments. Refresh cookies are Secure.
APP_ORIGIN=https://app.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.example.com/api
NEXT_PUBLIC_ENABLE_DEMO_FALLBACK=false

API_BIND_ADDRESS=127.0.0.1
API_PUBLISHED_PORT=4000
WEB_BIND_ADDRESS=127.0.0.1
WEB_PUBLISHED_PORT=3000

SWAGGER_ENABLED=false

# Generate each JWT secret with:
# node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
JWT_ACCESS_SECRET=replace-with-32-byte-base64url-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-32-byte-base64url-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
EMAIL_VERIFICATION_TTL=30m

DEMO_EMAIL=demo@example.com
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_NAME=
INITIAL_ADMIN_PASSWORD=

MAIL_PROVIDER=console
MAIL_FROM_EMAIL=no-reply@example.com
MAIL_FROM_NAME=PERSONAL_ERP
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=
