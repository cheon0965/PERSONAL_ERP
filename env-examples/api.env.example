# 권장 대상: <PERSONAL_ERP_SECRET_DIR>/api.env
# 앱 로컬 대체 대상: apps/api/.env

PORT=4000
APP_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
SWAGGER_ENABLED=true
# Generate each JWT secret with:
# node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
JWT_ACCESS_SECRET=replace-with-32-byte-base64url-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-32-byte-base64url-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
EMAIL_VERIFICATION_TTL=30m
# docker-compose.yml의 로컬 전용 폐기 가능 MySQL 초기화 사용자와 일치합니다.
DATABASE_URL=mysql://erp_user:local_erp_not_for_prod@localhost:3306/personal_erp
# 선택값이지만 `npm run test:prisma` 실행 시 권장합니다.
# 설정하지 않으면 Prisma 통합 테스트 모음은 DATABASE_URL로 대체합니다.
PRISMA_INTEGRATION_DATABASE_URL=mysql://erp_user:local_erp_not_for_prod@localhost:3306/personal_erp
DEMO_EMAIL=demo@example.com
# API 내부 스케줄러가 한국시간 매일 04:00에 DEMO_EMAIL 계정과
# 해당 계정만 단독 소유한 데모 워크스페이스를 삭제 후 재시드합니다.
DEMO_RESET_SCHEDULE_ENABLED=true
# API 내부 스케줄러가 한국시간 매일 03:30에 감사/보안 로그를
# 보존 기간 기준으로 정리합니다. 업무 데이터는 삭제하지 않습니다.
LOG_RETENTION_SCHEDULE_ENABLED=true
WORKSPACE_AUDIT_LOG_RETENTION_DAYS=180
SECURITY_THREAT_LOG_RETENTION_DAYS=365
# 단일 워크스페이스 소유자가 아니라 앱 전체 시스템 관리자로 시드됩니다.
INITIAL_ADMIN_EMAIL=owner@example.com
INITIAL_ADMIN_NAME=Initial Admin
INITIAL_ADMIN_PASSWORD=replace-with-local-initial-admin-password
MAIL_PROVIDER=console
MAIL_FROM_EMAIL=no-reply@example.com
MAIL_FROM_NAME=PERSONAL_ERP
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER_EMAIL=
