# Preferred setup:
# 1. Copy this file to `.secret-dir.local` at the repository root.
# 2. Point PERSONAL_ERP_SECRET_DIR to a directory that contains:
#    - api.env
#    - web.env
# 3. Copy env-examples/api.env.example to <PERSONAL_ERP_SECRET_DIR>/api.env.
# 4. Copy env-examples/web.env.example to <PERSONAL_ERP_SECRET_DIR>/web.env.
#
# App-local fallback setup is also supported:
# - copy env-examples/api.env.example to apps/api/.env
# - copy env-examples/web.env.example to apps/web/.env.local

PERSONAL_ERP_SECRET_DIR=C:\secrets\personal-erp
