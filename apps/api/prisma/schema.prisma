generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  BANK
  CASH
  CARD
}

enum CategoryKind {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  REVERSAL
}

enum RecurrenceFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum InsuranceCycle {
  MONTHLY
  YEARLY
}

enum FuelType {
  GASOLINE
  DIESEL
  LPG
  HYBRID
  ELECTRIC
}

enum VehicleMaintenanceCategory {
  INSPECTION
  REPAIR
  CONSUMABLE
  TIRE
  ACCIDENT
  OTHER
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  ACTIVE
  LOCKED
  DISABLED
}

enum TenantMembershipRole {
  OWNER
  MANAGER
  EDITOR
  VIEWER
}

enum TenantMembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  REMOVED
}

enum LedgerStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum AccountingPeriodStatus {
  OPEN
  IN_REVIEW
  CLOSING
  LOCKED
}

enum AuditActorType {
  TENANT_MEMBERSHIP
  SYSTEM
}

enum AccountingPeriodEventType {
  OPEN
  MOVE_TO_REVIEW
  START_CLOSING
  LOCK
  REOPEN
  FORCE_LOCK
}

enum AccountSubjectStatementType {
  BALANCE_SHEET
  PROFIT_AND_LOSS
}

enum AccountNormalSide {
  DEBIT
  CREDIT
}

enum AccountSubjectKind {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum LedgerTransactionFlowKind {
  INCOME
  EXPENSE
  TRANSFER
  ADJUSTMENT
  OPENING_BALANCE
  CARRY_FORWARD
}

enum PostingPolicyKey {
  INCOME_BASIC
  EXPENSE_BASIC
  TRANSFER_BASIC
  CARD_SPEND
  CARD_PAYMENT
  OPENING_BALANCE
  CARRY_FORWARD
  MANUAL_ADJUSTMENT
}

enum FundingAccountStatus {
  ACTIVE
  INACTIVE
  CLOSED
}

enum FundingAccountBootstrapStatus {
  NOT_REQUIRED
  PENDING
  COMPLETED
}

enum PlanItemStatus {
  DRAFT
  MATCHED
  CONFIRMED
  SKIPPED
  EXPIRED
}

enum ImportSourceKind {
  CARD_EXCEL
  BANK_CSV
  MANUAL_UPLOAD
  IM_BANK_PDF
}

enum ImportBatchParseStatus {
  PENDING
  COMPLETED
  PARTIAL
  FAILED
}

enum ImportedRowParseStatus {
  PENDING
  PARSED
  FAILED
  SKIPPED
}

enum ImportBatchCollectionJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  PARTIAL
  FAILED
  CANCELLED
}

enum ImportBatchCollectionJobRowStatus {
  PENDING
  RUNNING
  COLLECTED
  FAILED
  SKIPPED
}

enum CollectedTransactionStatus {
  COLLECTED
  REVIEWED
  READY_TO_POST
  POSTED
  CORRECTED
  LOCKED
}

enum JournalEntrySourceKind {
  COLLECTED_TRANSACTION
  PLAN_SETTLEMENT
  OPENING_BALANCE
  CARRY_FORWARD
  MANUAL_ADJUSTMENT
}

enum JournalEntryStatus {
  POSTED
  REVERSED
  SUPERSEDED
}

enum OpeningBalanceSourceKind {
  INITIAL_SETUP
  CARRY_FORWARD
}

enum BalanceSnapshotKind {
  OPENING
  CLOSING
}

enum FinancialStatementKind {
  STATEMENT_OF_FINANCIAL_POSITION
  MONTHLY_PROFIT_AND_LOSS
  CASH_FLOW_SUMMARY
  NET_WORTH_MOVEMENT
}

enum OperationalNoteKind {
  GENERAL
  MONTH_END
  EXCEPTION
  ALERT
  FOLLOW_UP
}

enum WorkspaceNavigationMenuItemType {
  GROUP
  PAGE
}

enum WorkspaceNavigationMenuMatchMode {
  EXACT
  PREFIX
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  passwordHash            String
  name                    String
  status                  UserStatus               @default(ACTIVE)
  isSystemAdmin           Boolean                  @default(false)
  lockedReason            String?                  @db.VarChar(191)
  lockedAt                DateTime?
  emailVerifiedAt         DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  settings                UserSetting?
  emailVerificationTokens EmailVerificationToken[]
  accounts                Account[]
  categories              Category[]
  recurringRules          RecurringRule[]
  insurancePolicies       InsurancePolicy[]
  vehicles                Vehicle[]
  authSessions            AuthSession[]
  memberships             TenantMembership[]

  @@index([isSystemAdmin])
  @@index([status])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, consumedAt])
}

model Tenant {
  id                          String                        @id @default(cuid())
  slug                        String                        @unique
  name                        String
  status                      TenantStatus                  @default(ACTIVE)
  defaultLedgerId             String?                       @unique
  createdAt                   DateTime                      @default(now())
  updatedAt                   DateTime                      @updatedAt
  defaultLedger               Ledger?                       @relation("TenantDefaultLedger", fields: [defaultLedgerId], references: [id], onDelete: SetNull)
  memberships                 TenantMembership[]
  ledgers                     Ledger[]                      @relation("TenantLedgers")
  accounts                    Account[]                     @relation("TenantAccounts")
  categories                  Category[]                    @relation("TenantCategories")
  recurringRules              RecurringRule[]               @relation("TenantRecurringRules")
  insurancePolicies           InsurancePolicy[]
  vehicles                    Vehicle[]
  periods                     AccountingPeriod[]
  periodStatusHistory         PeriodStatusHistory[]
  accountSubjects             AccountSubject[]
  ledgerTransactionTypes      LedgerTransactionType[]
  planItems                   PlanItem[]
  importBatches               ImportBatch[]
  collectedTransactions       CollectedTransaction[]
  journalEntries              JournalEntry[]
  openingBalanceSnapshots     OpeningBalanceSnapshot[]
  closingSnapshots            ClosingSnapshot[]
  carryForwardRecords         CarryForwardRecord[]
  financialStatementSnapshots FinancialStatementSnapshot[]
  operationalNotes            WorkspaceOperationalNote[]
  navigationMenuItems         WorkspaceNavigationMenuItem[]
}

model TenantMembership {
  id                    String                 @id @default(cuid())
  tenantId              String
  userId                String
  role                  TenantMembershipRole
  status                TenantMembershipStatus @default(ACTIVE)
  joinedAt              DateTime               @default(now())
  invitedByMembershipId String?
  lastAccessAt          DateTime?
  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedByMembership   TenantMembership?      @relation("TenantMembershipInviter", fields: [invitedByMembershipId], references: [id], onDelete: SetNull)
  invitedMemberships    TenantMembership[]     @relation("TenantMembershipInviter")

  @@unique([tenantId, userId])
  @@index([userId, status])
}

model TenantMembershipInvitation {
  id                    String               @id @default(cuid())
  tenantId              String
  email                 String
  normalizedEmail       String               @db.VarChar(191)
  role                  TenantMembershipRole
  tokenHash             String               @unique
  expiresAt             DateTime
  acceptedAt            DateTime?
  revokedAt             DateTime?
  invitedByMembershipId String
  createdAt             DateTime             @default(now())

  @@index([tenantId, normalizedEmail])
  @@index([tenantId, expiresAt])
}

model Ledger {
  id                          String                       @id @default(cuid())
  tenantId                    String
  name                        String
  baseCurrency                String                       @default("KRW") @db.VarChar(3)
  timezone                    String                       @default("Asia/Seoul")
  status                      LedgerStatus                 @default(ACTIVE)
  openedFromYearMonth         String                       @db.VarChar(7)
  closedThroughYearMonth      String?                      @db.VarChar(7)
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  tenant                      Tenant                       @relation("TenantLedgers", fields: [tenantId], references: [id], onDelete: Cascade)
  defaultForTenant            Tenant?                      @relation("TenantDefaultLedger")
  accounts                    Account[]                    @relation("LedgerAccounts")
  categories                  Category[]                   @relation("LedgerCategories")
  recurringRules              RecurringRule[]              @relation("LedgerRecurringRules")
  insurancePolicies           InsurancePolicy[]
  vehicles                    Vehicle[]
  periods                     AccountingPeriod[]
  periodStatusHistory         PeriodStatusHistory[]
  accountSubjects             AccountSubject[]
  ledgerTransactionTypes      LedgerTransactionType[]
  planItems                   PlanItem[]
  importBatches               ImportBatch[]
  collectedTransactions       CollectedTransaction[]
  journalEntries              JournalEntry[]
  openingBalanceSnapshots     OpeningBalanceSnapshot[]
  closingSnapshots            ClosingSnapshot[]
  carryForwardRecords         CarryForwardRecord[]
  financialStatementSnapshots FinancialStatementSnapshot[]
  operationalNotes            WorkspaceOperationalNote[]

  @@unique([tenantId, name])
  @@index([tenantId, status])
}

model AuthSession {
  id               String    @id
  userId           String
  refreshTokenHash String    @db.Text
  expiresAt        DateTime
  revokedAt        DateTime?
  supportTenantId  String?
  supportLedgerId  String?
  supportStartedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([userId, revokedAt])
  @@index([supportTenantId, supportLedgerId])
}

model WorkspaceAuditEvent {
  id                String   @id @default(cuid())
  tenantId          String
  ledgerId          String?
  actorUserId       String?
  actorMembershipId String?
  actorRole         String?  @db.VarChar(50)
  eventCategory     String   @db.VarChar(50)
  eventName         String   @db.VarChar(100)
  action            String?  @db.VarChar(100)
  resourceType      String?  @db.VarChar(100)
  resourceId        String?
  result            String   @db.VarChar(30)
  reason            String?  @db.VarChar(191)
  requestId         String?  @db.VarChar(191)
  path              String?  @db.VarChar(300)
  clientIpHash      String?  @db.VarChar(191)
  metadata          Json?
  occurredAt        DateTime @default(now())

  @@index([tenantId, occurredAt])
  @@index([tenantId, eventCategory, occurredAt])
  @@index([tenantId, action, occurredAt])
  @@index([tenantId, actorMembershipId, occurredAt])
  @@index([tenantId, requestId])
}

model SecurityThreatEvent {
  id            String   @id @default(cuid())
  severity      String   @db.VarChar(30)
  eventCategory String   @db.VarChar(50)
  eventName     String   @db.VarChar(100)
  source        String   @default("api") @db.VarChar(50)
  requestId     String?  @db.VarChar(191)
  path          String?  @db.VarChar(300)
  clientIpHash  String?  @db.VarChar(191)
  userId        String?
  sessionId     String?
  reason        String?  @db.VarChar(191)
  metadata      Json?
  occurredAt    DateTime @default(now())

  @@index([occurredAt])
  @@index([severity, occurredAt])
  @@index([eventCategory, occurredAt])
  @@index([eventName, occurredAt])
  @@index([clientIpHash, occurredAt])
  @@index([requestId])
}

model WorkspaceOperationalNote {
  id                 String              @id @default(cuid())
  tenantId           String
  ledgerId           String
  periodId           String?
  authorMembershipId String
  kind               OperationalNoteKind @default(GENERAL)
  title              String              @db.VarChar(191)
  body               String              @db.Text
  relatedHref        String?             @db.VarChar(300)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ledger             Ledger              @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  period             AccountingPeriod?   @relation(fields: [periodId], references: [id], onDelete: SetNull)

  @@index([tenantId, ledgerId, createdAt])
  @@index([tenantId, periodId, createdAt])
  @@index([tenantId, kind, createdAt])
}

model WorkspaceNavigationMenuItem {
  id          String                           @id @default(cuid())
  tenantId    String
  parentId    String?
  key         String                           @db.VarChar(100)
  itemType    WorkspaceNavigationMenuItemType  @default(PAGE)
  label       String                           @db.VarChar(100)
  description String?                          @db.VarChar(191)
  href        String?                          @db.VarChar(300)
  iconKey     String?                          @db.VarChar(50)
  matchMode   WorkspaceNavigationMenuMatchMode @default(PREFIX)
  sortOrder   Int                              @default(0)
  isVisible   Boolean                          @default(true)
  createdAt   DateTime                         @default(now())
  updatedAt   DateTime                         @updatedAt
  tenant      Tenant                           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent      WorkspaceNavigationMenuItem?     @relation("WorkspaceNavigationTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    WorkspaceNavigationMenuItem[]    @relation("WorkspaceNavigationTree")
  roles       WorkspaceNavigationMenuRole[]

  @@unique([tenantId, key])
  @@index([tenantId, parentId, sortOrder])
  @@index([tenantId, isVisible])
}

model WorkspaceNavigationMenuRole {
  id         String                      @id @default(cuid())
  menuItemId String
  role       TenantMembershipRole
  menuItem   WorkspaceNavigationMenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, role])
  @@index([role])
}

model UserSetting {
  id                    String   @id @default(cuid())
  userId                String   @unique
  minimumReserveWon     Decimal  @default(400000) @db.Decimal(19, 0)
  monthlySinkingFundWon Decimal  @default(140000) @db.Decimal(19, 0)
  timezone              String   @default("Asia/Seoul")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                     String                        @id @default(cuid())
  userId                 String
  tenantId               String
  ledgerId               String
  name                   String
  normalizedName         String                        @db.VarChar(191)
  type                   AccountType
  balanceWon             Decimal                       @default(0) @db.Decimal(19, 0)
  sortOrder              Int                           @default(0)
  status                 FundingAccountStatus          @default(ACTIVE)
  bootstrapStatus        FundingAccountBootstrapStatus @default(NOT_REQUIRED)
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt
  user                   User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant                 Tenant                        @relation("TenantAccounts", fields: [tenantId], references: [id], onDelete: Cascade)
  ledger                 Ledger                        @relation("LedgerAccounts", fields: [ledgerId], references: [id], onDelete: Cascade)
  recurringRules         RecurringRule[]
  insurancePolicies      InsurancePolicy[]
  planItems              PlanItem[]
  importBatches          ImportBatch[]
  collectedTransactions  CollectedTransaction[]
  journalLines           JournalLine[]
  balanceSnapshotLines   BalanceSnapshotLine[]
  vehicleDefaultProfiles Vehicle[]                     @relation("VehicleDefaultFundingAccount")

  @@unique([ledgerId, normalizedName])
  @@index([userId, sortOrder])
  @@index([tenantId, ledgerId, sortOrder])
}

model Category {
  id                                String                 @id @default(cuid())
  userId                            String
  tenantId                          String
  ledgerId                          String
  name                              String
  normalizedName                    String                 @db.VarChar(191)
  kind                              CategoryKind
  sortOrder                         Int                    @default(0)
  isActive                          Boolean                @default(true)
  createdAt                         DateTime               @default(now())
  updatedAt                         DateTime               @updatedAt
  user                              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant                            Tenant                 @relation("TenantCategories", fields: [tenantId], references: [id], onDelete: Cascade)
  ledger                            Ledger                 @relation("LedgerCategories", fields: [ledgerId], references: [id], onDelete: Cascade)
  recurringRules                    RecurringRule[]
  insurancePolicies                 InsurancePolicy[]
  planItems                         PlanItem[]
  collectedTransactions             CollectedTransaction[]
  vehicleDefaultFuelProfiles        Vehicle[]              @relation("VehicleDefaultFuelCategory")
  vehicleDefaultMaintenanceProfiles Vehicle[]              @relation("VehicleDefaultMaintenanceCategory")

  @@unique([ledgerId, kind, normalizedName])
  @@index([userId, kind, sortOrder])
  @@index([tenantId, ledgerId, kind, sortOrder])
}

model RecurringRule {
  id                      String                 @id @default(cuid())
  userId                  String
  tenantId                String
  ledgerId                String
  accountId               String
  categoryId              String?
  ledgerTransactionTypeId String?
  title                   String
  amountWon               Decimal                @db.Decimal(19, 0)
  frequency               RecurrenceFrequency
  dayOfMonth              Int?
  startDate               DateTime
  endDate                 DateTime?
  nextRunDate             DateTime?
  isActive                Boolean                @default(true)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  user                    User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant                  Tenant                 @relation("TenantRecurringRules", fields: [tenantId], references: [id], onDelete: Cascade)
  ledger                  Ledger                 @relation("LedgerRecurringRules", fields: [ledgerId], references: [id], onDelete: Cascade)
  account                 Account                @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category                Category?              @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  ledgerTransactionType   LedgerTransactionType? @relation(fields: [ledgerTransactionTypeId], references: [id], onDelete: SetNull)
  linkedInsurancePolicy   InsurancePolicy?       @relation("InsurancePolicyLinkedRecurringRule")
  planItems               PlanItem[]

  @@index([userId, isActive, nextRunDate])
  @@index([tenantId, ledgerId, isActive])
}

model AccountingPeriod {
  id                          String                       @id @default(cuid())
  tenantId                    String
  ledgerId                    String
  year                        Int
  month                       Int
  startDate                   DateTime
  endDate                     DateTime
  status                      AccountingPeriodStatus       @default(OPEN)
  nextJournalEntrySequence    Int                          @default(1)
  openedAt                    DateTime                     @default(now())
  lockedAt                    DateTime?
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  tenant                      Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ledger                      Ledger                       @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  statusHistory               PeriodStatusHistory[]
  planItems                   PlanItem[]
  importBatches               ImportBatch[]
  collectedTransactions       CollectedTransaction[]
  journalEntries              JournalEntry[]
  openingBalanceSnapshot      OpeningBalanceSnapshot?
  closingSnapshot             ClosingSnapshot?
  carryForwardSourceRecord    CarryForwardRecord?          @relation("CarryForwardFromPeriod")
  carryForwardTargetRecord    CarryForwardRecord?          @relation("CarryForwardToPeriod")
  financialStatementSnapshots FinancialStatementSnapshot[]
  operationalNotes            WorkspaceOperationalNote[]

  @@unique([ledgerId, year, month])
  @@index([tenantId, ledgerId, status])
}

model PeriodStatusHistory {
  id                String                    @id @default(cuid())
  tenantId          String
  ledgerId          String
  periodId          String
  fromStatus        AccountingPeriodStatus?
  toStatus          AccountingPeriodStatus
  eventType         AccountingPeriodEventType
  reason            String?                   @db.Text
  actorType         AuditActorType
  actorMembershipId String?
  changedAt         DateTime                  @default(now())
  tenant            Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ledger            Ledger                    @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  period            AccountingPeriod          @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@index([periodId, changedAt])
}

model AccountSubject {
  id                   String                      @id @default(cuid())
  tenantId             String
  ledgerId             String
  code                 String
  name                 String
  statementType        AccountSubjectStatementType
  normalSide           AccountNormalSide
  subjectKind          AccountSubjectKind
  isSystem             Boolean                     @default(false)
  isActive             Boolean                     @default(true)
  sortOrder            Int                         @default(0)
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  tenant               Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ledger               Ledger                      @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  journalLines         JournalLine[]
  balanceSnapshotLines BalanceSnapshotLine[]

  @@unique([ledgerId, code])
  @@index([tenantId, ledgerId, sortOrder])
}

// Physical DB model for the domain TransactionType. The existing enum TransactionType
// stays in place to avoid breaking the current API code during the first backbone round.
model LedgerTransactionType {
  id                    String                    @id @default(cuid())
  tenantId              String
  ledgerId              String
  code                  String
  name                  String
  flowKind              LedgerTransactionFlowKind
  postingPolicyKey      PostingPolicyKey
  isActive              Boolean                   @default(true)
  sortOrder             Int                       @default(0)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  tenant                Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ledger                Ledger                    @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  recurringRules        RecurringRule[]
  planItems             PlanItem[]
  collectedTransactions CollectedTransaction[]

  @@unique([ledgerId, code])
  @@index([tenantId, ledgerId, sortOrder])
}

model PlanItem {
  id                          String                @id @default(cuid())
  tenantId                    String
  ledgerId                    String
  periodId                    String
  recurringRuleId             String?
  ledgerTransactionTypeId     String
  fundingAccountId            String
  categoryId                  String?
  title                       String
  plannedAmount               Decimal               @db.Decimal(19, 0)
  plannedDate                 DateTime
  status                      PlanItemStatus        @default(DRAFT)
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt
  tenant                      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ledger                      Ledger                @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  period                      AccountingPeriod      @relation(fields: [periodId], references: [id], onDelete: Cascade)
  recurringRule               RecurringRule?        @relation(fields: [recurringRuleId], references: [id], onDelete: SetNull)
  ledgerTransactionType       LedgerTransactionType @relation(fields: [ledgerTransactionTypeId], references: [id], onDelete: Restrict)
  fundingAccount              Account               @relation(fields: [fundingAccountId], references: [id], onDelete: Restrict)
  category                    Category?             @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  matchedCollectedTransaction CollectedTransaction? @relation("PlanItemMatchedCollectedTransaction")
  postedJournalEntry          JournalEntry?         @relation("JournalEntrySourcePlanItem")

  @@unique([periodId, recurringRuleId, plannedDate])
  @@index([periodId, status, plannedDate])
  @@index([tenantId, ledgerId, plannedDate])
}

model ImportBatch {
  id                     String                 @id @default(cuid())
  tenantId               String
  ledgerId               String
  periodId               String?
  sourceKind             ImportSourceKind
  fileName               String
  fileHash               String                 @db.VarChar(191)
  fundingAccountId       String?
  rowCount               Int                    @default(0)
  parseStatus            ImportBatchParseStatus @default(PENDING)
  uploadedByMembershipId String
  uploadedAt             DateTime               @default(now())
  tenant                 Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ledger                 Ledger                 @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  period                 AccountingPeriod?      @relation(fields: [periodId], references: [id], onDelete: SetNull)
  fundingAccount         Account?               @relation(fields: [fundingAccountId], references: [id], onDelete: SetNull)
  rows                   ImportedRow[]
  collectedTransactions  CollectedTransaction[]

  @@index([ledgerId, uploadedAt])
  @@index([fileHash])
  @@index([fundingAccountId])
}

model ImportedRow {
  id                          String                 @id @default(cuid())
  batchId                     String
  rowNumber                   Int
  rawPayload                  Json
  parseStatus                 ImportedRowParseStatus @default(PENDING)
  parseError                  String?                @db.Text
  sourceFingerprint           String?                @db.VarChar(191)
  batch                       ImportBatch            @relation(fields: [batchId], references: [id], onDelete: Cascade)
  createdCollectedTransaction CollectedTransaction?  @relation("ImportedRowCreatedCollectedTransaction")

  @@unique([batchId, rowNumber])
  @@index([sourceFingerprint])
}

model ImportBatchCollectionJob {
  id                      String                         @id @default(cuid())
  tenantId                String
  ledgerId                String
  importBatchId           String
  requestedByMembershipId String
  status                  ImportBatchCollectionJobStatus @default(PENDING)
  requestedRowCount       Int                            @default(0)
  processedRowCount       Int                            @default(0)
  succeededCount          Int                            @default(0)
  failedCount             Int                            @default(0)
  requestPayload          Json
  errorMessage            String?                        @db.Text
  startedAt               DateTime?
  finishedAt              DateTime?
  heartbeatAt             DateTime?
  createdAt               DateTime                       @default(now())
  updatedAt               DateTime                       @updatedAt
  rows                    ImportBatchCollectionJobRow[]

  @@index([tenantId, ledgerId, importBatchId, createdAt], map: "ibcj_tenant_ledger_batch_created_idx")
  @@index([tenantId, ledgerId, status], map: "ibcj_tenant_ledger_status_idx")
}

model ImportBatchCollectionJobRow {
  id                     String                            @id @default(cuid())
  jobId                  String
  importedRowId          String
  rowNumber              Int
  status                 ImportBatchCollectionJobRowStatus @default(PENDING)
  collectedTransactionId String?
  message                String?                           @db.Text
  startedAt              DateTime?
  finishedAt             DateTime?
  createdAt              DateTime                          @default(now())
  updatedAt              DateTime                          @updatedAt
  job                    ImportBatchCollectionJob          @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, importedRowId], map: "ibcjr_job_row_key")
  @@index([importedRowId], map: "ibcjr_imported_row_idx")
}

model ImportBatchCollectionLock {
  id                   String   @id @default(cuid())
  tenantId             String
  ledgerId             String
  importBatchId        String
  jobId                String
  lockedByMembershipId String
  expiresAt            DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([tenantId, ledgerId], map: "ibcl_tenant_ledger_key")
  @@unique([jobId], map: "ibcl_job_key")
  @@index([expiresAt], map: "ibcl_expires_at_idx")
}

model CollectedTransaction {
  id                      String                     @id @default(cuid())
  tenantId                String
  ledgerId                String
  periodId                String?
  importBatchId           String?
  importedRowId           String?                    @unique
  ledgerTransactionTypeId String
  fundingAccountId        String
  categoryId              String?
  matchedPlanItemId       String?                    @unique
  title                   String
  occurredOn              DateTime
  amount                  Decimal                    @db.Decimal(19, 0)
  status                  CollectedTransactionStatus @default(COLLECTED)
  sourceFingerprint       String?                    @db.VarChar(191)
  memo                    String?                    @db.Text
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  tenant                  Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ledger                  Ledger                     @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  period                  AccountingPeriod?          @relation(fields: [periodId], references: [id], onDelete: SetNull)
  importBatch             ImportBatch?               @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  importedRow             ImportedRow?               @relation("ImportedRowCreatedCollectedTransaction", fields: [importedRowId], references: [id], onDelete: SetNull)
  ledgerTransactionType   LedgerTransactionType      @relation(fields: [ledgerTransactionTypeId], references: [id], onDelete: Restrict)
  fundingAccount          Account                    @relation(fields: [fundingAccountId], references: [id], onDelete: Restrict)
  category                Category?                  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  matchedPlanItem         PlanItem?                  @relation("PlanItemMatchedCollectedTransaction", fields: [matchedPlanItemId], references: [id], onDelete: SetNull)
  postedJournalEntry      JournalEntry?              @relation("JournalEntrySourceCollectedTransaction")
  linkedFuelLog           FuelLog?                   @relation("FuelLogLinkedCollectedTransaction")
  linkedMaintenanceLog    VehicleMaintenanceLog?     @relation("VehicleMaintenanceLogLinkedCollectedTransaction")

  @@index([ledgerId, status, occurredOn])
  @@index([ledgerId, sourceFingerprint])
}

model JournalEntry {
  id                           String                 @id @default(cuid())
  tenantId                     String
  ledgerId                     String
  periodId                     String
  entryNumber                  String                 @db.VarChar(50)
  entryDate                    DateTime
  sourceKind                   JournalEntrySourceKind
  sourceCollectedTransactionId String?                @unique
  sourcePlanItemId             String?                @unique
  status                       JournalEntryStatus     @default(POSTED)
  memo                         String?                @db.Text
  reversesJournalEntryId       String?                @unique
  correctsJournalEntryId       String?
  correctionReason             String?                @db.Text
  createdByActorType           AuditActorType
  createdByMembershipId        String?
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
  tenant                       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ledger                       Ledger                 @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  period                       AccountingPeriod       @relation(fields: [periodId], references: [id], onDelete: Cascade)
  sourceCollectedTransaction   CollectedTransaction?  @relation("JournalEntrySourceCollectedTransaction", fields: [sourceCollectedTransactionId], references: [id], onDelete: SetNull)
  sourcePlanItem               PlanItem?              @relation("JournalEntrySourcePlanItem", fields: [sourcePlanItemId], references: [id], onDelete: SetNull)
  reversesJournalEntry         JournalEntry?          @relation("JournalEntryReversal", fields: [reversesJournalEntryId], references: [id], onDelete: SetNull)
  reversedByJournalEntry       JournalEntry?          @relation("JournalEntryReversal")
  correctsJournalEntry         JournalEntry?          @relation("JournalEntryCorrection", fields: [correctsJournalEntryId], references: [id], onDelete: SetNull)
  correctionEntries            JournalEntry[]         @relation("JournalEntryCorrection")
  createdCarryForwardRecord    CarryForwardRecord?    @relation("CarryForwardCreatedJournalEntry")
  lines                        JournalLine[]

  @@unique([ledgerId, entryNumber])
  @@index([periodId, entryDate])
  @@index([correctsJournalEntryId])
}

model JournalLine {
  id               String         @id @default(cuid())
  journalEntryId   String
  lineNumber       Int
  accountSubjectId String
  fundingAccountId String?
  debitAmount      Decimal        @default(0) @db.Decimal(19, 0)
  creditAmount     Decimal        @default(0) @db.Decimal(19, 0)
  description      String?        @db.Text
  journalEntry     JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountSubject   AccountSubject @relation(fields: [accountSubjectId], references: [id], onDelete: Restrict)
  fundingAccount   Account?       @relation(fields: [fundingAccountId], references: [id], onDelete: SetNull)

  @@unique([journalEntryId, lineNumber])
  @@index([accountSubjectId])
}

model OpeningBalanceSnapshot {
  id                    String                   @id @default(cuid())
  tenantId              String
  ledgerId              String
  effectivePeriodId     String                   @unique
  sourceKind            OpeningBalanceSourceKind @default(INITIAL_SETUP)
  createdAt             DateTime                 @default(now())
  createdByActorType    AuditActorType
  createdByMembershipId String?
  tenant                Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ledger                Ledger                   @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  effectivePeriod       AccountingPeriod         @relation(fields: [effectivePeriodId], references: [id], onDelete: Restrict)
  lines                 BalanceSnapshotLine[]    @relation("OpeningSnapshotLines")
}

model ClosingSnapshot {
  id                   String                @id @default(cuid())
  tenantId             String
  ledgerId             String
  periodId             String                @unique
  lockedAt             DateTime
  totalAssetAmount     Decimal               @db.Decimal(19, 0)
  totalLiabilityAmount Decimal               @db.Decimal(19, 0)
  totalEquityAmount    Decimal               @db.Decimal(19, 0)
  periodPnLAmount      Decimal               @db.Decimal(19, 0)
  createdAt            DateTime              @default(now())
  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ledger               Ledger                @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  period               AccountingPeriod      @relation(fields: [periodId], references: [id], onDelete: Cascade)
  lines                BalanceSnapshotLine[] @relation("ClosingSnapshotLines")
  carryForwardRecord   CarryForwardRecord?
}

model BalanceSnapshotLine {
  id                String                  @id @default(cuid())
  snapshotKind      BalanceSnapshotKind
  openingSnapshotId String?
  closingSnapshotId String?
  accountSubjectId  String
  fundingAccountId  String?
  balanceAmount     Decimal                 @db.Decimal(19, 0)
  openingSnapshot   OpeningBalanceSnapshot? @relation("OpeningSnapshotLines", fields: [openingSnapshotId], references: [id], onDelete: Cascade)
  closingSnapshot   ClosingSnapshot?        @relation("ClosingSnapshotLines", fields: [closingSnapshotId], references: [id], onDelete: Cascade)
  accountSubject    AccountSubject          @relation(fields: [accountSubjectId], references: [id], onDelete: Restrict)
  fundingAccount    Account?                @relation(fields: [fundingAccountId], references: [id], onDelete: SetNull)

  @@index([openingSnapshotId, accountSubjectId])
  @@index([closingSnapshotId, accountSubjectId])
}

model FinancialStatementSnapshot {
  id            String                 @id @default(cuid())
  tenantId      String
  ledgerId      String
  periodId      String
  statementKind FinancialStatementKind
  currency      String                 @db.VarChar(3)
  payload       Json
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ledger        Ledger                 @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  period        AccountingPeriod       @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([periodId, statementKind])
  @@index([tenantId, ledgerId, createdAt])
}

model CarryForwardRecord {
  id                      String           @id @default(cuid())
  tenantId                String
  ledgerId                String
  fromPeriodId            String           @unique
  toPeriodId              String           @unique
  sourceClosingSnapshotId String           @unique
  createdJournalEntryId   String?          @unique
  createdAt               DateTime         @default(now())
  createdByActorType      AuditActorType
  createdByMembershipId   String?
  tenant                  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ledger                  Ledger           @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  fromPeriod              AccountingPeriod @relation("CarryForwardFromPeriod", fields: [fromPeriodId], references: [id], onDelete: Cascade)
  toPeriod                AccountingPeriod @relation("CarryForwardToPeriod", fields: [toPeriodId], references: [id], onDelete: Cascade)
  sourceClosingSnapshot   ClosingSnapshot  @relation(fields: [sourceClosingSnapshotId], references: [id], onDelete: Cascade)
  createdJournalEntry     JournalEntry?    @relation("CarryForwardCreatedJournalEntry", fields: [createdJournalEntryId], references: [id], onDelete: SetNull)

  @@index([tenantId, ledgerId, createdAt])
}

model InsurancePolicy {
  id                    String         @id @default(cuid())
  userId                String
  tenantId              String
  ledgerId              String
  accountId             String?
  categoryId            String?
  recurringStartDate    DateTime?
  linkedRecurringRuleId String?        @unique
  provider              String
  normalizedProvider    String         @db.VarChar(191)
  productName           String
  normalizedProductName String         @db.VarChar(191)
  monthlyPremiumWon     Decimal        @db.Decimal(19, 0)
  paymentDay            Int
  cycle                 InsuranceCycle @default(MONTHLY)
  renewalDate           DateTime?
  maturityDate          DateTime?
  isActive              Boolean        @default(true)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant                Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ledger                Ledger         @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  account               Account?       @relation(fields: [accountId], references: [id], onDelete: SetNull)
  category              Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  linkedRecurringRule   RecurringRule? @relation("InsurancePolicyLinkedRecurringRule", fields: [linkedRecurringRuleId], references: [id], onDelete: SetNull)

  @@unique([ledgerId, normalizedProvider, normalizedProductName], map: "InsurancePolicy_ledger_normprov_normprod_key")
  @@index([userId, isActive])
  @@index([tenantId, ledgerId, isActive])
  @@index([accountId])
  @@index([categoryId])
}

model Vehicle {
  id                                String                  @id @default(cuid())
  userId                            String
  tenantId                          String
  ledgerId                          String
  name                              String
  normalizedName                    String                  @db.VarChar(191)
  manufacturer                      String?
  fuelType                          FuelType
  initialOdometerKm                 Int
  estimatedFuelEfficiencyKmPerLiter Decimal?                @db.Decimal(10, 2)
  defaultFundingAccountId           String?
  defaultFuelCategoryId             String?
  defaultMaintenanceCategoryId      String?
  operatingExpensePlanOptIn         Boolean                 @default(false)
  createdAt                         DateTime                @default(now())
  updatedAt                         DateTime                @updatedAt
  user                              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant                            Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ledger                            Ledger                  @relation(fields: [ledgerId], references: [id], onDelete: Cascade)
  defaultFundingAccount             Account?                @relation("VehicleDefaultFundingAccount", fields: [defaultFundingAccountId], references: [id], onDelete: SetNull)
  defaultFuelCategory               Category?               @relation("VehicleDefaultFuelCategory", fields: [defaultFuelCategoryId], references: [id], onDelete: SetNull)
  defaultMaintenanceCategory        Category?               @relation("VehicleDefaultMaintenanceCategory", fields: [defaultMaintenanceCategoryId], references: [id], onDelete: SetNull)
  fuelLogs                          FuelLog[]
  maintenanceLogs                   VehicleMaintenanceLog[]

  @@unique([ledgerId, normalizedName])
  @@index([defaultFundingAccountId])
  @@index([defaultFuelCategoryId])
  @@index([defaultMaintenanceCategoryId])
  @@index([userId, name])
  @@index([tenantId, ledgerId, name])
}

model FuelLog {
  id                           String                @id @default(cuid())
  vehicleId                    String
  linkedCollectedTransactionId String?               @unique
  filledOn                     DateTime
  odometerKm                   Int
  liters                       Decimal               @db.Decimal(10, 3)
  amountWon                    Decimal               @db.Decimal(19, 0)
  unitPriceWon                 Decimal               @db.Decimal(19, 0)
  isFullTank                   Boolean               @default(false)
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt
  vehicle                      Vehicle               @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  linkedCollectedTransaction   CollectedTransaction? @relation("FuelLogLinkedCollectedTransaction", fields: [linkedCollectedTransactionId], references: [id], onDelete: SetNull)

  @@index([vehicleId, filledOn])
}

model VehicleMaintenanceLog {
  id                           String                     @id @default(cuid())
  vehicleId                    String
  linkedCollectedTransactionId String?                    @unique
  performedOn                  DateTime
  odometerKm                   Int
  category                     VehicleMaintenanceCategory
  vendor                       String?
  description                  String
  amountWon                    Decimal                    @db.Decimal(19, 0)
  memo                         String?                    @db.Text
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt
  vehicle                      Vehicle                    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  linkedCollectedTransaction   CollectedTransaction?      @relation("VehicleMaintenanceLogLinkedCollectedTransaction", fields: [linkedCollectedTransactionId], references: [id], onDelete: SetNull)

  @@index([vehicleId, performedOn])
}
