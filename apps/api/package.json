{
  "name": "@personal-erp/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run prisma:generate && node ../../scripts/run-with-root-env.cjs nest start --watch --sourceRoot . --entryFile apps/api/src/main",
    "build": "npm run prisma:generate && node ../../scripts/run-with-root-env.cjs nest build",
    "start": "npm run prisma:generate && node ../../scripts/run-with-root-env.cjs node dist/apps/api/src/main.js",
    "lint": "eslint src prisma test --ext .ts --max-warnings=0",
    "typecheck": "tsc --noEmit --incremental false -p tsconfig.test.json",
    "clean:test-dist": "node ../../scripts/clean-test-dist.cjs .test-dist",
    "compile:test": "tsc -p tsconfig.test-run.json",
    "test": "npm run clean:test-dist && npm run compile:test && node --test --test-concurrency=1 --test-isolation=none .test-dist/apps/api/test/*.test.js",
    "test:prisma": "node ../../scripts/run-with-root-env.cjs node ../../scripts/run-api-prisma-integration.cjs",
    "prisma:generate": "node ../../scripts/run-with-root-env.cjs prisma generate",
    "prisma:migrate:dev": "node ../../scripts/run-with-root-env.cjs prisma migrate dev",
    "prisma:migrate:deploy": "node ../../scripts/run-with-root-env.cjs prisma migrate deploy",
    "prisma:migrate:deploy:latest-baseline": "node ../../scripts/run-with-root-env.cjs node ../../scripts/deploy-latest-prisma-baseline.cjs",
    "prisma:migrate:repair:concurrency-guardrails": "node ../../scripts/run-with-root-env.cjs node ../../scripts/repair-concurrency-guardrails-migration.cjs",
    "prisma:migrate:reset": "node ../../scripts/run-with-root-env.cjs prisma migrate reset",
    "prisma:migrate:status": "node ../../scripts/run-with-root-env.cjs prisma migrate status",
    "prisma:push:unsafe": "node ../../scripts/run-with-root-env.cjs prisma db push",
    "prisma:backfill:phase1": "npm run prisma:generate && node ../../scripts/run-with-root-env.cjs tsx prisma/backfill-phase1-backbone.ts",
    "prisma:seed": "npm run prisma:generate && node ../../scripts/run-with-root-env.cjs tsx prisma/seed.ts",
    "prisma:seed:reset": "npm run prisma:generate && node ../../scripts/run-with-root-env.cjs tsx prisma/seed.ts --reset"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.11",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.11",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.11",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^11.3.2",
    "@personal-erp/money": "0.1.0",
    "@prisma/client": "^6.4.1",
    "argon2": "^0.41.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "mysql2": "^3.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.6",
    "@nestjs/testing": "^11.0.11",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
