# Preferred setup:
# 1. Copy this file to `.env` at the repository root.
# 2. Point PERSONAL_ERP_SECRET_DIR to a directory that contains:
#    - api.env
#    - web.env
# 3. Put API-only secrets such as Gmail API mail settings in api.env.
#
# Local fallback setup is also supported:
# - copy apps/api/.env.example to apps/api/.env
# - copy apps/web/.env.local.example to apps/web/.env.local

PERSONAL_ERP_SECRET_DIR=C:\secrets\personal-erp
