{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@personal-erp/contracts": ["packages/contracts/src/index.ts"],
      "@personal-erp/contracts/*": ["packages/contracts/src/*"]
    }
  }
}
